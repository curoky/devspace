#!/opt/sb/profile/s6/bin/execlineb -P

s6-envdir -Lf -- /run/s6/container_environment

fdmove -c 2 1

importas WORKSPACE_ROOT_HOST WORKSPACE_ROOT_HOST

export PYTHONPATH "/app"

exec /opt/sb/bin/uv run --directory /app --no-sync python -m codespace.agent serve
  --host 0.0.0.0
  --port 8001
  --workspace-root-host ${WORKSPACE_ROOT_HOST}
  --podman-uri unix:///tmp/podmanxd.sock
